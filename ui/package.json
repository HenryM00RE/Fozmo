{
  "name": "fozmo-ui",
  "private": true,
  "version": "0.0.2",
  "license": "MIT",
  "engines": {
    "node": "22.x"
  },
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "test": "vitest run --exclude e2e-real/**",
    "test:coverage": "vitest run --coverage --exclude e2e-real/**",
    "test:e2e": "playwright test",
    "test:e2e:real": "playwright test --config playwright.real.config.ts",
    "test:e2e:smoke": "playwright test --grep @smoke",
    "test:e2e:ui": "playwright test --ui",
    "lint": "biome lint src vite.config.ts",
    "lint:fix": "biome lint --write src vite.config.ts",
    "format": "biome format --write src vite.config.ts",
    "format:check": "biome format --check src vite.config.ts",
    "check": "biome check src vite.config.ts",
    "check:fix": "biome check --write src vite.config.ts",
    "audit": "npm audit --audit-level=high",
    "license:check": "license-checker-rseidelsohn --production --excludePrivatePackages --onlyAllow 'MIT;Apache-2.0;BSD-2-Clause;BSD-3-Clause;ISC;0BSD;Zlib;Unicode-3.0;Unicode-DFS-2016'"
  },
  "dependencies": {
    "qrcode": "^1.5.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@biomejs/biome": "^2.5.1",
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.0.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "@vitest/coverage-v8": "^4.1.10",
    "ajv": "^8.20.0",
    "jsdom": "^29.1.1",
    "json-schema-to-typescript": "^15.0.4",
    "license-checker-rseidelsohn": "4.4.2",
    "typescript": "^5.8.0",
    "vite": "^7.0.0",
    "vitest": "^4.1.9"
  }
}
