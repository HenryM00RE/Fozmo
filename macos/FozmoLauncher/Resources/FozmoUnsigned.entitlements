<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Ad-hoc signatures have no shared Team ID. The unsigned public build
         needs this entitlement to load its separately ad-hoc-signed Sparkle
         framework. Sparkle update checks remain disabled in this mode. -->
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>
</dict>
</plist>
