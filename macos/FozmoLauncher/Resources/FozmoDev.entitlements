<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Ad-hoc signatures have no shared Team ID. This development-only
         entitlement lets the launcher load the separately ad-hoc-signed
         Sparkle framework. Public builds use Fozmo.entitlements instead. -->
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>
</dict>
</plist>
